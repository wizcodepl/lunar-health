{
    "name": "wizcodepl/lunar-health",
    "description": "Spatie Health checks for Lunar PHP (carts, orders, search, queues)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "lunarphp/core": "^1.0",
        "spatie/laravel-health": "^1.22"
    },
    "autoload": {
        "psr-4": {
            "WizcodePl\\LunarHealth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WizcodePl\\LunarHealth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WizcodePl\\LunarHealth\\LunarHealthServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
